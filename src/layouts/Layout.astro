---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  titleEn?: string;
  description?: string;
  descriptionEn?: string;
  activeKey?: string;
}

const {
  title = 'Boquete · Tierras Altas de Chiriquí',
  titleEn = 'Boquete · Chiriquí Highlands',
  description = 'Descubre Boquete: volcán Barú, café Geisha, quetzales, aventura y cultura en las tierras altas de Chiriquí, Panamá.',
  descriptionEn = 'Discover Boquete: Barú Volcano, Geisha coffee, quetzals, adventure and culture in the Chiriquí highlands, Panama.',
  activeKey = 'home',
} = Astro.props;
---

<!doctype html>
<html lang="es" data-lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="title-en" content={titleEn} />
  <meta name="title-es" content={title} />
  <meta name="desc-en" content={descriptionEn} />
  <meta name="desc-es" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=Hanken+Grotesk:wght@400;500;600;700&family=Spectral:ital,wght@1,400;1,500&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <Header activeKey={activeKey} />
  <main>
    <slot />
  </main>
  <Footer />

  <script>
    // Language switcher
    const LANG_KEYS = ['es', 'en'] as const;
    type Lang = typeof LANG_KEYS[number];

    function applyLang(lang: Lang) {
      const html = document.documentElement;
      html.setAttribute('data-lang', lang);
      html.setAttribute('lang', lang);
      localStorage.setItem('bq-lang', lang);

      // Update toggle buttons
      document.querySelectorAll<HTMLElement>('[data-lang-btn]').forEach(btn => {
        const isActive = btn.dataset.langBtn === lang;
        btn.style.background = isActive ? '#2C3A2A' : 'transparent';
        btn.style.color = isActive ? '#F7F1E6' : '#3D3328';
      });

      // Update page title and meta description
      const titleMeta = document.querySelector<HTMLMetaElement>(`meta[name="title-${lang}"]`);
      if (titleMeta) document.title = titleMeta.content;
      const descMeta = document.querySelector<HTMLMetaElement>(`meta[name="desc-${lang}"]`);
      const descTag = document.querySelector<HTMLMetaElement>('meta[name="description"]');
      if (descMeta && descTag) descTag.content = descMeta.content;
    }

    // Init
    const saved = localStorage.getItem('bq-lang') as Lang | null;
    const lang: Lang = (saved && LANG_KEYS.includes(saved)) ? saved : 'es';
    applyLang(lang);

    // Listen for clicks on lang buttons
    document.addEventListener('click', (e: MouseEvent) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>('[data-lang-btn]');
      if (btn?.dataset.langBtn) applyLang(btn.dataset.langBtn as Lang);
    });

    // Mobile menu toggle
    const burger = document.getElementById('mobile-burger');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileOverlay = document.getElementById('mobile-overlay');

    function closeMobile() {
      mobileMenu?.classList.add('hidden');
      mobileOverlay?.classList.add('hidden');
    }

    burger?.addEventListener('click', () => {
      mobileMenu?.classList.toggle('hidden');
      mobileOverlay?.classList.toggle('hidden');
    });

    mobileOverlay?.addEventListener('click', closeMobile);
    document.querySelectorAll('.mobile-nav-link').forEach(link => {
      link.addEventListener('click', closeMobile);
    });
  </script>
</body>
</html>
