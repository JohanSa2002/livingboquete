---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import GalleryMasonry from '../components/GalleryMasonry';
import { PLACES, EVENTS, POSTS, GALLERY, GALLERY_CATS } from '../data/data';

const homePosts = POSTS.slice(0, 3);
---

<Layout activeKey="home">

  <!-- HERO -->
  <section style="position:relative;min-height:94vh;display:flex;align-items:flex-end;overflow:hidden">
    <img
      id="hero-poster"
      src="/hero-poster.webp"
      alt="Vista de Boquete"
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:1"
    />
    <video
      id="hero-video"
      autoplay muted playsinline
      poster="/hero-poster.webp"
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:2"
    >
      <source src="/hero-boquete.webm" type="video/webm" />
    </video>
    <div style="position:absolute;inset:0;z-index:3;background:linear-gradient(180deg,rgba(20,28,18,.34) 0%,rgba(20,28,18,.06) 32%,rgba(18,20,12,.62) 78%,rgba(18,20,12,.86) 100%)"></div>

    <!-- Replay button -->
    <button id="hero-replay" style="display:none;position:absolute;bottom:24px;right:24px;z-index:5;background:rgba(247,241,230,.12);backdrop-filter:blur(8px);border:1px solid rgba(247,241,230,.25);color:#F7F1E6;padding:9px 16px;border-radius:999px;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;display:none;align-items:center;gap:7px;transition:background .2s">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
      <span class="lang-es">Reproducir</span><span class="lang-en" hidden>Replay</span>
    </button>

    <div class="pad-sec" style="position:relative;z-index:4;max-width:1240px;margin:0 auto;padding:0 26px 76px;width:100%;color:#F7F1E6">
      <div style="display:inline-flex;align-items:center;gap:9px;background:rgba(247,241,230,.14);backdrop-filter:blur(6px);border:1px solid rgba(247,241,230,.28);padding:8px 15px;border-radius:999px;font-size:13px;font-weight:600;letter-spacing:.04em;margin-bottom:22px;animation:fadein 1s both">
        <span style="width:7px;height:7px;border-radius:50%;background:#C8964A"></span>
        <span class="lang-es">Tierras altas de Chiriquí · Panamá</span>
        <span class="lang-en" hidden>Chiriquí Highlands · Panama</span>
      </div>
      <h1 class="hero-h1" style="font-family:'Bricolage Grotesque';font-weight:800;font-size:clamp(80px,12vw,180px);line-height:.86;letter-spacing:-.03em;margin:0 0 18px;text-shadow:0 4px 40px rgba(0,0,0,.3)">Boquete</h1>
      <p style="font-family:'Spectral';font-style:italic;font-size:clamp(20px,2.6vw,30px);max-width:620px;line-height:1.32;margin:0 0 34px;color:#F0E7D6">
        <span class="lang-es">Donde la montaña respira café, niebla y aventura.</span>
        <span class="lang-en" hidden>Where the mountains breathe coffee, mist and adventure.</span>
      </p>
      <div style="display:flex;gap:14px;flex-wrap:wrap">
        <a href="#atractivos" style="background:#B95C36;color:#F7F1E6;font-weight:700;font-size:16px;padding:16px 28px;border-radius:999px;text-decoration:none;box-shadow:0 14px 34px -12px rgba(185,92,54,.9)">
          <span class="lang-es">Explorar la comunidad</span>
          <span class="lang-en" hidden>Explore the community</span>
        </a>
        <a href="/alquiler" style="background:rgba(247,241,230,.12);backdrop-filter:blur(6px);border:1px solid rgba(247,241,230,.5);color:#F7F1E6;font-weight:700;font-size:16px;padding:16px 28px;border-radius:999px;text-decoration:none">
          <span class="lang-es">Ver alquileres</span>
          <span class="lang-en" hidden>View stays</span>
        </a>
      </div>
    </div>
  </section>

  <!-- TOP ATTRACTIONS -->
  <section id="atractivos" class="pad-sec rv" style="max-width:1240px;margin:0 auto;padding:96px 26px 30px">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:20px;margin-bottom:42px;flex-wrap:wrap">
      <div style="max-width:560px">
        <div style="font-size:13px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:#B95C36;margin-bottom:14px">
          <span class="lang-es">Principales atractivos</span>
          <span class="lang-en" hidden>Top attractions</span>
        </div>
        <h2 style="font-family:'Bricolage Grotesque';font-weight:700;font-size:clamp(34px,4.4vw,52px);line-height:1.02;letter-spacing:-.02em;margin:0;color:#251D14">
          <span class="lang-es">Seis razones para perderse —y reencontrarse— en las montañas de Boquete.</span>
          <span class="lang-en" hidden>Six reasons to get lost — and find yourself — in the mountains of Boquete.</span>
        </h2>
      </div>
    </div>
    <div class="cols-3" style="display:grid;grid-template-columns:repeat(3,1fr);gap:26px">
      {PLACES.map(p => (
        <div class="place-card" style="border-radius:18px;overflow:hidden;background:#fff;border:1px solid rgba(37,29,20,.09);box-shadow:0 1px 2px rgba(37,29,20,.04);display:block">
          <div style="position:relative;aspect-ratio:4/3.1;overflow:hidden">
            <img src={p.img} alt={p.name.es} style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover" loading="lazy" />
            <span style="position:absolute;top:13px;left:13px;background:rgba(20,28,18,.62);backdrop-filter:blur(4px);color:#F7F1E6;font-size:12px;font-weight:700;letter-spacing:.04em;padding:6px 12px;border-radius:999px">
              <span class="lang-es">{p.cat.es}</span><span class="lang-en" hidden>{p.cat.en}</span>
            </span>
          </div>
          <div style="padding:20px 21px 23px">
            <h3 style="font-family:'Bricolage Grotesque';font-weight:700;font-size:22px;margin:0 0 9px;color:#251D14">
              <span class="lang-es">{p.name.es}</span><span class="lang-en" hidden>{p.name.en}</span>
            </h3>
            <p style="font-size:14.5px;line-height:1.55;color:#5A4F42;margin:0 0 14px">
              <span class="lang-es">{p.short.es}</span><span class="lang-en" hidden>{p.short.en}</span>
            </p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- UPCOMING EVENTS -->
  <section class="pad-sec rv" style="max-width:1240px;margin:0 auto;padding:74px 26px 30px">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:20px;margin-bottom:34px;flex-wrap:wrap">
      <div>
        <div style="font-size:13px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:#B95C36;margin-bottom:12px">
          <span class="lang-es">Próximos eventos</span><span class="lang-en" hidden>Upcoming events</span>
        </div>
        <h2 style="font-family:'Bricolage Grotesque';font-weight:700;font-size:clamp(30px,3.6vw,42px);margin:0;color:#251D14;letter-spacing:-.02em">
          <span class="lang-es">Ferias, música y tradición durante todo el año.</span>
          <span class="lang-en" hidden>Fairs, music and tradition throughout the year.</span>
        </h2>
      </div>
    </div>
    <div class="cols-3" style="display:grid;grid-template-columns:repeat(3,1fr);gap:22px">
      {EVENTS.map(e => (
        <div style="position:relative;border-radius:18px;overflow:hidden;min-height:300px;display:flex;flex-direction:column;justify-content:flex-end">
          <img src={e.img} alt={e.name.es} style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover" loading="lazy" />
          <div style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(20,28,18,.12),rgba(18,20,12,.85))"></div>
          <div style="position:absolute;top:15px;left:15px;background:#F7F1E6;border-radius:13px;text-align:center;padding:9px 13px;line-height:1">
            <div style="font-family:'Bricolage Grotesque';font-weight:800;font-size:25px;color:#B95C36">{e.d}</div>
            <div style="font-size:11px;font-weight:700;letter-spacing:.1em;color:#5A4F42;margin-top:2px">
              <span class="lang-es">{e.m.es}</span><span class="lang-en" hidden>{e.m.en}</span>
            </div>
          </div>
          <div style="position:relative;z-index:2;padding:20px;color:#F7F1E6">
            <span style="font-size:12px;font-weight:700;letter-spacing:.06em;color:#E7C98C">
              <span class="lang-es">{e.cat.es}</span><span class="lang-en" hidden>{e.cat.en}</span>
            </span>
            <h3 style="font-family:'Bricolage Grotesque';font-weight:700;font-size:21px;margin:7px 0 6px;line-height:1.1">
              <span class="lang-es">{e.name.es}</span><span class="lang-en" hidden>{e.name.en}</span>
            </h3>
            <p style="font-size:13.5px;color:#D8CDBA;margin:0">
              <span class="lang-es">{e.place.es} · {e.time.es}</span>
              <span class="lang-en" hidden>{e.place.en} · {e.time.en}</span>
            </p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- BLOG -->
  <section style="background:#EFE7D6;margin-top:74px">
    <div class="pad-sec rv" style="max-width:1240px;margin:0 auto;padding:74px 26px">
      <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:20px;margin-bottom:34px;flex-wrap:wrap">
        <div>
          <div style="font-size:13px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:#B95C36;margin-bottom:12px">
            <span class="lang-es">Del blog</span><span class="lang-en" hidden>From the blog</span>
          </div>
          <h2 style="font-family:'Bricolage Grotesque';font-weight:700;font-size:clamp(30px,3.6vw,42px);margin:0;color:#251D14;letter-spacing:-.02em">
            <span class="lang-es">Historias, guías y consejos para tu viaje.</span>
            <span class="lang-en" hidden>Stories, guides and tips for your trip.</span>
          </h2>
        </div>
        <a href="/blog" style="color:#2C3A2A;font-weight:700;text-decoration:none;border-bottom:2px solid #C8964A;padding-bottom:3px;white-space:nowrap">
          <span class="lang-es">Ver todos</span><span class="lang-en" hidden>See all</span> →
        </a>
      </div>
      <div class="cols-3" style="display:grid;grid-template-columns:repeat(3,1fr);gap:26px">
        {homePosts.map(b => (
          <a href={`/blog/${b.id}`} style="cursor:pointer;text-decoration:none;color:inherit;display:block">
            <div style="position:relative;aspect-ratio:3/2.1;border-radius:16px;overflow:hidden;margin-bottom:16px">
              <img src={b.img} alt={b.title.es} style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover" loading="lazy" />
            </div>
            <div style="display:flex;gap:10px;align-items:center;font-size:12.5px;color:#8A7D69;margin-bottom:9px">
              <span style="color:#B95C36;font-weight:700">
                <span class="lang-es">{b.cat.es}</span><span class="lang-en" hidden>{b.cat.en}</span>
              </span>
              <span>·</span>
              <span><span class="lang-es">{b.date.es}</span><span class="lang-en" hidden>{b.date.en}</span></span>
            </div>
            <h3 style="font-family:'Bricolage Grotesque';font-weight:700;font-size:21px;line-height:1.18;margin:0 0 9px;color:#251D14">
              <span class="lang-es">{b.title.es}</span><span class="lang-en" hidden>{b.title.en}</span>
            </h3>
            <p style="font-size:14.5px;line-height:1.55;color:#5A4F42;margin:0">
              <span class="lang-es">{b.excerpt.es}</span><span class="lang-en" hidden>{b.excerpt.en}</span>
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- GALLERY PREVIEW -->
  <section class="pad-sec" style="max-width:1240px;margin:0 auto;padding:74px 26px 20px">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:20px;margin-bottom:30px;flex-wrap:wrap">
      <div>
        <div style="font-size:13px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:#B95C36;margin-bottom:12px">
          <span class="lang-es">Galería</span><span class="lang-en" hidden>Gallery</span>
        </div>
        <h2 style="font-family:'Bricolage Grotesque';font-weight:700;font-size:clamp(30px,3.6vw,42px);margin:0;color:#251D14;letter-spacing:-.02em">
          <span class="lang-es">Un vistazo a la vida en las tierras altas.</span>
          <span class="lang-en" hidden>A glimpse of life in the highlands.</span>
        </h2>
      </div>
    </div>
    <GalleryMasonry
      client:idle
      items={GALLERY}
      categories={GALLERY_CATS}
    />
  </section>

  <!-- LEAD FORM -->
  <section id="contacto" style="background:#2C3A2A">
    <div class="lead-wrap" style="max-width:1240px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;min-height:600px">

      <!-- Left: Copy -->
      <div style="padding:clamp(40px,5vw,80px) clamp(26px,4vw,64px);display:flex;flex-direction:column;justify-content:center">
        <div style="font-size:12px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:#C8964A;margin-bottom:18px">
          <span class="lang-es">Guía gratuita</span>
          <span class="lang-en" hidden>Complimentary guide</span>
        </div>
        <h2 style="font-family:'Spectral';font-weight:700;font-size:clamp(32px,4.2vw,52px);line-height:1.08;letter-spacing:-.01em;margin:0 0 20px;color:#F7F1E6">
          <span class="lang-es">Antes de planear la mudanza, ten el panorama completo.</span>
          <span class="lang-en" hidden>Before you plan the move, get the full picture.</span>
        </h2>
        <p style="font-size:16px;line-height:1.65;color:#A99C86;margin:0 0 32px;max-width:440px">
          <span class="lang-es">Nuestra guía práctica para retirarse en Boquete reúne las preguntas importantes en un solo lugar, claro y accesible.</span>
          <span class="lang-en" hidden>Our practical introduction to retiring in Boquete brings the important questions into one calm, readable place.</span>
        </p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px 32px">
          {[
            { es: 'Por qué eligen Panamá', en: 'Why people choose Panama' },
            { es: 'Qué hace único a Boquete', en: 'What makes Boquete different' },
            { es: 'Costo de vida', en: 'Cost of living considerations' },
            { es: 'Comprar como extranjero', en: 'Buying as a foreigner' },
            { es: 'Residencia y trámites', en: 'Residency basics' },
            { es: 'Salud y servicios', en: 'Healthcare nearby' },
            { es: 'Preguntas clave antes de comprar', en: 'Questions before buying' },
            { es: 'Checklist para tu visita', en: 'Visit planning checklist' },
          ].map(item => (
            <div style="display:flex;align-items:baseline;gap:8px;font-size:14.5px;color:#D8CDBA;line-height:1.6">
              <span style="color:#C8964A;font-size:13px;flex:none">+</span>
              <span>
                <span class="lang-es">{item.es}</span>
                <span class="lang-en" hidden>{item.en}</span>
              </span>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Form card -->
      <div style="padding:clamp(32px,4vw,60px) clamp(26px,4vw,56px);display:flex;align-items:center">
        <div id="lead-card" style="background:#F7F1E6;border-radius:20px;padding:clamp(28px,3.4vw,44px);width:100%;box-shadow:0 30px 60px -20px rgba(0,0,0,.25)">
          <h3 style="font-family:'Bricolage Grotesque';font-weight:800;font-size:clamp(22px,2.6vw,30px);color:#251D14;margin:0 0 6px">
            <span class="lang-es">Recibe la guía gratis</span>
            <span class="lang-en" hidden>Send me the free guide</span>
          </h3>
          <p style="font-size:14.5px;color:#5A4F42;margin:0 0 24px;line-height:1.5">
            <span class="lang-es">Un punto de partida útil, directo a tu correo.</span>
            <span class="lang-en" hidden>A useful starting point, delivered to your inbox.</span>
          </p>

          <form id="lead-form" style="display:flex;flex-direction:column;gap:16px">
            <!-- Nombre -->
            <div>
              <label class="lead-label">
                <span class="lang-es">Nombre completo</span><span class="lang-en" hidden>Full name</span>
              </label>
              <input name="nombre" required class="lead-input" />
            </div>

            <!-- Email + Celular -->
            <div class="form-row" style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
              <div>
                <label class="lead-label">
                  <span class="lang-es">Correo</span><span class="lang-en" hidden>Email</span>
                </label>
                <input name="email" type="email" required class="lead-input" />
              </div>
              <div>
                <label class="lead-label">
                  <span class="lang-es">Celular / WhatsApp</span><span class="lang-en" hidden>Phone / WhatsApp</span>
                </label>
                <input name="celular" type="tel" class="lead-input" />
              </div>
            </div>

            <!-- País + Retiro -->
            <div class="form-row" style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
              <div>
                <label class="lead-label">
                  <span class="lang-es">País</span><span class="lang-en" hidden>Country</span>
                </label>
                <input name="pais" class="lead-input" />
              </div>
              <div>
                <label class="lead-label">
                  <span class="lang-es">¿Planeas retirarte?</span><span class="lang-en" hidden>Planning to retire?</span>
                </label>
                <select name="retiro" required class="lead-select lang-es">
                  <option value="" disabled selected>Elige una</option>
                  <option value="si">Sí</option>
                  <option value="talvez">Tal vez</option>
                  <option value="investigando">Estoy investigando</option>
                </select>
                <select name="retiro" required class="lead-select lang-en">
                  <option value="" disabled selected>Choose one</option>
                  <option value="si">Yes</option>
                  <option value="talvez">Maybe</option>
                  <option value="investigando">I'm researching</option>
                </select>
              </div>
            </div>

            <!-- Timeline + Interés -->
            <div class="form-row" style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
              <div>
                <label class="lead-label">
                  <span class="lang-es">Horizonte de tiempo</span><span class="lang-en" hidden>Timeline</span>
                </label>
                <select name="timeline" required class="lead-select lang-es">
                  <option value="" disabled selected>Elige una</option>
                  <option value="0-6">0–6 meses</option>
                  <option value="6-12">6–12 meses</option>
                  <option value="1ano">1 año</option>
                  <option value="2anos">2+ años</option>
                </select>
                <select name="timeline" required class="lead-select lang-en">
                  <option value="" disabled selected>Choose one</option>
                  <option value="0-6">0–6 months</option>
                  <option value="6-12">6–12 months</option>
                  <option value="1ano">1 year</option>
                  <option value="2anos">2+ years</option>
                </select>
              </div>
              <div>
                <label class="lead-label">
                  <span class="lang-es">Interés principal</span><span class="lang-en" hidden>Main interest</span>
                </label>
                <select name="interes" required class="lead-select lang-es">
                  <option value="" disabled selected>Elige una</option>
                  <option value="retiro">Retiro</option>
                  <option value="estilo">Estilo de vida</option>
                  <option value="casa">Comprar casa</option>
                  <option value="inversiones">Inversiones</option>
                  <option value="info">Información local</option>
                </select>
                <select name="interes" required class="lead-select lang-en">
                  <option value="" disabled selected>Choose one</option>
                  <option value="retiro">Retirement</option>
                  <option value="estilo">Lifestyle</option>
                  <option value="casa">Buy a home</option>
                  <option value="inversiones">Investments</option>
                  <option value="info">Local info</option>
                </select>
              </div>
            </div>

            <!-- Submit -->
            <button type="submit" class="lead-btn">
              <span class="lang-es">Envíame la guía →</span>
              <span class="lang-en" hidden>Send me the guide →</span>
            </button>
          </form>

          <p style="text-align:center;font-size:13px;color:#8A7D69;margin:14px 0 0">
            <span class="lang-es">Sin presión, sin spam.</span>
            <span class="lang-en" hidden>No pressure, no crowded inbox.</span>
          </p>

          <!-- Success message -->
          <div id="lead-success" style="display:none;text-align:center;padding:32px 10px">
            <div style="width:52px;height:52px;border-radius:50%;background:#2C3A2A;color:#C8964A;display:inline-flex;align-items:center;justify-content:center;font-size:24px;font-weight:800;margin-bottom:16px">✓</div>
            <h3 style="font-family:'Bricolage Grotesque';font-weight:800;font-size:24px;color:#251D14;margin:0 0 8px">
              <span class="lang-es">¡Gracias!</span>
              <span class="lang-en" hidden>Thank you!</span>
            </h3>
            <p style="font-size:15px;color:#5A4F42;margin:0">
              <span class="lang-es">Revisa tu correo — la guía va en camino.</span>
              <span class="lang-en" hidden>Check your inbox — the guide is on its way.</span>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    // Hero video: play once, then show poster + replay button
    const heroVideo = document.getElementById('hero-video') as HTMLVideoElement;
    const heroReplay = document.getElementById('hero-replay') as HTMLButtonElement;

    if (heroVideo && heroReplay) {
      heroVideo.addEventListener('ended', () => {
        heroVideo.style.opacity = '0';
        heroVideo.style.transition = 'opacity .8s ease';
        heroReplay.style.display = 'inline-flex';
      });

      heroReplay.addEventListener('click', () => {
        heroReplay.style.display = 'none';
        heroVideo.currentTime = 0;
        heroVideo.style.opacity = '1';
        heroVideo.play();
      });
    }

    function syncLeadSelects() {
      const lang = document.documentElement.getAttribute('data-lang') || 'es';
      document.querySelectorAll<HTMLSelectElement>('#lead-form select').forEach(s => {
        const isActive = s.classList.contains(`lang-${lang}`);
        s.disabled = !isActive;
      });
    }
    syncLeadSelects();
    new MutationObserver(syncLeadSelects).observe(document.documentElement, { attributes: true, attributeFilter: ['data-lang'] });

    document.getElementById('lead-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const data = Object.fromEntries(new FormData(form));
      try {
        await fetch('/api/leads', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
      } catch {}
      form.style.display = 'none';
      (document.querySelector('#lead-card > p:last-of-type') as HTMLElement).style.display = 'none';
      document.getElementById('lead-success')!.style.display = 'block';
    });
  </script>

  <!-- Spacer so #contacto can scroll to center of viewport -->
  <div aria-hidden="true" style="height:50vh"></div>

</Layout>

