---
import Layout from '../layouts/Layout.astro';
---

<Layout activeKey="contact" title="Contacto · Boquete" titleEn="Contact · Boquete">

  <section class="pad-sec" style="max-width:1180px;margin:0 auto;padding:64px 26px 96px">
    <div class="split-2" style="display:grid;grid-template-columns:.85fr 1.15fr;gap:54px;align-items:start">

      <!-- Left info -->
      <div>
        <div style="font-size:13px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:#B95C36;margin-bottom:14px">
          <span class="lang-es">Contacto</span><span class="lang-en" hidden>Get in touch</span>
        </div>
        <h1 style="font-family:'Bricolage Grotesque';font-weight:800;font-size:clamp(36px,4.6vw,56px);line-height:1.0;letter-spacing:-.025em;margin:0 0 18px;color:#251D14">
          <span class="lang-es">Planeemos tu visita</span>
          <span class="lang-en" hidden>Let's plan your visit</span>
        </h1>
        <p style="font-size:17px;line-height:1.62;color:#5A4F42;margin:0 0 32px">
          <span class="lang-es">Déjanos tus datos y un anfitrión local te responderá con una propuesta a tu medida.</span>
          <span class="lang-en" hidden>Leave us your details and a local host will reply with a tailored proposal.</span>
        </p>

        <div style="position:relative;aspect-ratio:4/3.2;border-radius:20px;overflow:hidden;margin-bottom:26px">
          <img src="https://picsum.photos/seed/contact-boquete/800/640" alt="Anfitrión local" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover" />
        </div>

        <div style="display:flex;flex-direction:column;gap:13px;font-size:15px;color:#3D3328">
          <div style="display:flex;gap:11px;align-items:center">
            <span style="width:34px;height:34px;border-radius:10px;background:#EFE7D6;display:flex;align-items:center;justify-content:center;flex:none">📍</span>
            Av. Central, Boquete · Chiriquí, Panamá
          </div>
          <div style="display:flex;gap:11px;align-items:center">
            <span style="width:34px;height:34px;border-radius:10px;background:#EFE7D6;display:flex;align-items:center;justify-content:center;flex:none">✉</span>
            hola@visitboquete.pa
          </div>
          <div style="display:flex;gap:11px;align-items:center">
            <span style="width:34px;height:34px;border-radius:10px;background:#EFE7D6;display:flex;align-items:center;justify-content:center;flex:none">📞</span>
            +507 720 0000
          </div>
        </div>
      </div>

      <!-- Right form -->
      <div style="background:#fff;border:1px solid rgba(37,29,20,.1);border-radius:24px;padding:clamp(26px,4vw,42px);box-shadow:0 24px 60px -40px rgba(37,29,20,.6)">
        <div id="form-success" style="display:none;text-align:center;padding:34px 8px;animation:fadein .4s both">
          <div style="width:74px;height:74px;border-radius:50%;background:#2C3A2A;color:#C8964A;display:flex;align-items:center;justify-content:center;font-size:36px;margin:0 auto 22px">✓</div>
          <h2 style="font-family:'Bricolage Grotesque';font-weight:700;font-size:28px;margin:0 0 12px;color:#251D14">
            <span class="lang-es">¡Mensaje enviado!</span><span class="lang-en" hidden>Message sent!</span>
          </h2>
          <p style="font-size:16px;line-height:1.6;color:#5A4F42;max-width:380px;margin:0 auto 26px">
            <span class="lang-es">Nuestro equipo te contactará pronto con una propuesta personalizada.</span>
            <span class="lang-en" hidden>Our team will be in touch soon with a personalised proposal.</span>
          </p>
          <button id="form-reset" style="cursor:pointer;background:#EFE7D6;border:none;color:#251D14;font-weight:700;font-size:15px;padding:13px 24px;border-radius:12px">
            <span class="lang-es">Enviar otro mensaje</span><span class="lang-en" hidden>Send another message</span>
          </button>
        </div>

        <form id="contact-form" style="display:flex;flex-direction:column;gap:17px" novalidate>
          <div class="cols-2" style="display:grid;grid-template-columns:1fr 1fr;gap:17px">
            <label style="display:flex;flex-direction:column;gap:7px;font-size:13.5px;font-weight:700;color:#3D3328">
              <span class="lang-es">Nombre</span><span class="lang-en" hidden>Name</span>
              <input name="nombre" required placeholder="—" style="background:#F7F1E6;border:1px solid rgba(37,29,20,.14);border-radius:11px;padding:13px 14px;font-size:15px;color:#251D14;outline:none" />
            </label>
            <label style="display:flex;flex-direction:column;gap:7px;font-size:13.5px;font-weight:700;color:#3D3328">
              <span class="lang-es">Correo electrónico</span><span class="lang-en" hidden>Email</span>
              <input name="email" type="email" required placeholder="—" style="background:#F7F1E6;border:1px solid rgba(37,29,20,.14);border-radius:11px;padding:13px 14px;font-size:15px;color:#251D14;outline:none" />
            </label>
          </div>
          <div class="cols-2" style="display:grid;grid-template-columns:1fr 1fr;gap:17px">
            <label style="display:flex;flex-direction:column;gap:7px;font-size:13.5px;font-weight:700;color:#3D3328">
              <span class="lang-es">Teléfono</span><span class="lang-en" hidden>Phone</span>
              <input name="telefono" placeholder="—" style="background:#F7F1E6;border:1px solid rgba(37,29,20,.14);border-radius:11px;padding:13px 14px;font-size:15px;color:#251D14;outline:none" />
            </label>
            <label style="display:flex;flex-direction:column;gap:7px;font-size:13.5px;font-weight:700;color:#3D3328">
              <span class="lang-es">País</span><span class="lang-en" hidden>Country</span>
              <select name="pais" required style="background:#F7F1E6;border:1px solid rgba(37,29,20,.14);border-radius:11px;padding:13px 14px;font-size:15px;color:#251D14;outline:none">
                <option value="">—</option>
                {[
                  { es: 'Panamá', en: 'Panama' },
                  { es: 'Estados Unidos', en: 'United States' },
                  { es: 'Colombia', en: 'Colombia' },
                  { es: 'Costa Rica', en: 'Costa Rica' },
                  { es: 'México', en: 'Mexico' },
                  { es: 'España', en: 'Spain' },
                  { es: 'Alemania', en: 'Germany' },
                  { es: 'Francia', en: 'France' },
                  { es: 'Reino Unido', en: 'United Kingdom' },
                  { es: 'Otro', en: 'Other' },
                ].map(c => (
                  <option value={c.es} data-es={c.es} data-en={c.en}>{c.es}</option>
                ))}
              </select>
            </label>
          </div>
          <label style="display:flex;flex-direction:column;gap:7px;font-size:13.5px;font-weight:700;color:#3D3328">
            <span class="lang-es">Tema de consulta</span><span class="lang-en" hidden>Topic</span>
            <select name="tema" required style="background:#F7F1E6;border:1px solid rgba(37,29,20,.14);border-radius:11px;padding:13px 14px;font-size:15px;color:#251D14;outline:none">
              <option value="">—</option>
              {[
                { es: 'Alojamiento', en: 'Accommodation' },
                { es: 'Senderismo y naturaleza', en: 'Hiking & nature' },
                { es: 'Ruta del café', en: 'Coffee route' },
                { es: 'Eventos y festivales', en: 'Events & festivals' },
                { es: 'Información general', en: 'General information' },
              ].map(t => (
                <option value={t.es} data-es={t.es} data-en={t.en}>{t.es}</option>
              ))}
            </select>
          </label>
          <label style="display:flex;flex-direction:column;gap:7px;font-size:13.5px;font-weight:700;color:#3D3328">
            <span class="lang-es">Mensaje</span><span class="lang-en" hidden>Message</span>
            <textarea name="mensaje" rows={4} placeholder="..." style="background:#F7F1E6;border:1px solid rgba(37,29,20,.14);border-radius:11px;padding:13px 14px;font-size:15px;color:#251D14;outline:none;resize:vertical;font-family:inherit"></textarea>
          </label>
          <button type="submit" style="cursor:pointer;background:#B95C36;color:#F7F1E6;border:none;font-weight:800;font-size:16px;padding:16px;border-radius:13px;box-shadow:0 14px 30px -14px rgba(185,92,54,.9)">
            <span class="lang-es">Enviar mensaje</span><span class="lang-en" hidden>Send message</span>
          </button>
        </form>
      </div>
    </div>
  </section>

</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success')!;
  const reset = document.getElementById('form-reset')!;

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    form.style.display = 'none';
    success.style.display = 'block';
  });

  reset.addEventListener('click', () => {
    form.reset();
    success.style.display = 'none';
    form.style.display = 'flex';
  });

  function updateSelectLang() {
    const lang = document.documentElement.getAttribute('data-lang') || 'es';
    document.querySelectorAll<HTMLOptionElement>('option[data-es]').forEach(opt => {
      opt.textContent = opt.dataset[lang] || opt.dataset.es || '';
    });
  }
  updateSelectLang();
  const obs = new MutationObserver(updateSelectLang);
  obs.observe(document.documentElement, { attributes: true, attributeFilter: ['data-lang'] });
</script>
