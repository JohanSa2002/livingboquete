---
import Layout from '../../layouts/Layout.astro';
import { PLACES } from '../../data/data';
---

<Layout activeKey="places" title="Lugares · Boquete" titleEn="Places · Boquete">

  <section class="pad-sec" style="max-width:1240px;margin:0 auto;padding:70px 26px 0">
    <div style="font-size:13px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:#B95C36;margin-bottom:14px">
      <span class="lang-es">Lugares turísticos</span><span class="lang-en" hidden>Places to visit</span>
    </div>
    <h1 style="font-family:'Bricolage Grotesque';font-weight:800;font-size:clamp(40px,6vw,72px);line-height:.98;letter-spacing:-.025em;margin:0 0 14px;color:#251D14">
      <span class="lang-es">Qué hacer en Boquete</span>
      <span class="lang-en" hidden>What to do in Boquete</span>
    </h1>
    <p style="font-size:18px;color:#5A4F42;max-width:560px;margin:0 0 46px">
      <span class="lang-es">Aventura, naturaleza y cultura a los pies del Volcán Barú.</span>
      <span class="lang-en" hidden>Adventure, nature and culture at the foot of Barú Volcano.</span>
    </p>
  </section>

  <section class="pad-sec" style="max-width:1240px;margin:0 auto;padding:0 26px 96px">
    <div class="cols-3" style="display:grid;grid-template-columns:repeat(3,1fr);gap:28px">
      {PLACES.map(p => (
        <a href={`/lugares/${p.id}`} class="place-card rv" style="cursor:pointer;border-radius:18px;overflow:hidden;background:#fff;border:1px solid rgba(37,29,20,.09);text-decoration:none;color:inherit;display:block">
          <div style="position:relative;aspect-ratio:4/3.1;overflow:hidden">
            <img src={p.img} alt={p.name.es} style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover" loading="lazy" />
            <span style="position:absolute;top:13px;left:13px;background:rgba(20,28,18,.62);backdrop-filter:blur(4px);color:#F7F1E6;font-size:12px;font-weight:700;padding:6px 12px;border-radius:999px">
              <span class="lang-es">{p.cat.es}</span><span class="lang-en" hidden>{p.cat.en}</span>
            </span>
          </div>
          <div style="padding:20px 21px 23px">
            <h3 style="font-family:'Bricolage Grotesque';font-weight:700;font-size:22px;margin:0 0 9px;color:#251D14">
              <span class="lang-es">{p.name.es}</span><span class="lang-en" hidden>{p.name.en}</span>
            </h3>
            <p style="font-size:14.5px;line-height:1.55;color:#5A4F42;margin:0 0 14px">
              <span class="lang-es">{p.short.es}</span><span class="lang-en" hidden>{p.short.en}</span>
            </p>
            <span style="color:#B95C36;font-weight:700;font-size:14px">
              <span class="lang-es">Ver más</span><span class="lang-en" hidden>See more</span> →
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

</Layout>

<style>
  .place-card { transition: transform .25s, box-shadow .25s; }
  .place-card:hover { transform: translateY(-5px); box-shadow: 0 22px 40px -22px rgba(37,29,20,.4); }
</style>
