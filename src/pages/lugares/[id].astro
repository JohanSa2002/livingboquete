---
import Layout from '../../layouts/Layout.astro';
import { PLACES } from '../../data/data';

export function getStaticPaths() {
  return PLACES.map(p => ({ params: { id: p.id }, props: { place: p } }));
}

const { place } = Astro.props;
---

<Layout activeKey="places" title={`${place.name.es} · Boquete`} titleEn={`${place.name.en} · Boquete`}>

  <!-- HERO IMAGE -->
  <section style="position:relative;height:52vh;min-height:380px;display:flex;align-items:flex-end;overflow:hidden">
    <img src={place.img} alt={place.name.es} style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover" />
    <div style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(20,28,18,.2),rgba(18,20,12,.8))"></div>
    <div class="pad-sec" style="position:relative;z-index:2;max-width:1100px;margin:0 auto;padding:0 26px 40px;width:100%;color:#F7F1E6">
      <a href="/lugares" style="cursor:pointer;display:inline-flex;align-items:center;gap:7px;color:#E4DAC6;font-weight:600;font-size:14px;text-decoration:none;margin-bottom:18px">
        ← <span class="lang-es">Volver a lugares</span><span class="lang-en" hidden>Back to places</span>
      </a>
      <span style="display:block;font-size:13px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#E7C98C;margin-bottom:8px">
        <span class="lang-es">{place.cat.es}</span><span class="lang-en" hidden>{place.cat.en}</span>
      </span>
      <h1 style="font-family:'Bricolage Grotesque';font-weight:800;font-size:clamp(38px,5.5vw,64px);line-height:1;letter-spacing:-.02em;margin:0">
        <span class="lang-es">{place.name.es}</span><span class="lang-en" hidden>{place.name.en}</span>
      </h1>
    </div>
  </section>

  <!-- CONTENT -->
  <section class="pad-sec" style="max-width:1100px;margin:0 auto;padding:48px 26px 96px">
    <div class="split-2" style="display:grid;grid-template-columns:1.6fr 1fr;gap:48px;align-items:start">

      <!-- Left: gallery + description -->
      <div>
        <div class="cols-3" style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:32px">
          {['-g1','-g2','-g3'].map(suf => (
            <div style="position:relative;aspect-ratio:1;border-radius:12px;overflow:hidden">
              <img src={`https://picsum.photos/seed/${place.id}${suf}/400/400`} alt={place.name.es} style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover" loading="lazy" />
            </div>
          ))}
        </div>

        <p style="font-size:17px;line-height:1.72;color:#3D3328;margin:0 0 30px">
          <span class="lang-es">{place.long.es}</span>
          <span class="lang-en" hidden>{place.long.en}</span>
        </p>

        <div style="border-top:1px solid rgba(37,29,20,.12);padding-top:24px">
          <h3 style="font-family:'Bricolage Grotesque';font-weight:700;font-size:21px;margin:0 0 14px;color:#251D14">
            <span class="lang-es">Recomendaciones</span><span class="lang-en" hidden>Recommendations</span>
          </h3>
          <div style="display:flex;flex-direction:column;gap:11px">
            {place.tips.es.map((tip, i) => (
              <div style="display:flex;gap:12px;align-items:flex-start">
                <span style="width:22px;height:22px;border-radius:50%;background:#EFE7D6;color:#B95C36;font-weight:800;font-size:13px;display:flex;align-items:center;justify-content:center;flex:none;margin-top:1px">✓</span>
                <span style="font-size:15.5px;line-height:1.5;color:#3D3328">
                  <span class="lang-es">{tip}</span>
                  <span class="lang-en" hidden>{place.tips.en[i]}</span>
                </span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Right: info card + map -->
      <div style="position:sticky;top:92px;display:flex;flex-direction:column;gap:16px">
        <div style="background:#fff;border:1px solid rgba(37,29,20,.1);border-radius:18px;padding:24px;box-shadow:0 12px 30px -22px rgba(37,29,20,.5)">
          <div style="margin-bottom:18px">
            <div style="font-size:12px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#8A7D69;margin-bottom:6px">
              <span class="lang-es">Horarios</span><span class="lang-en" hidden>Hours</span>
            </div>
            <div style="font-size:15px;color:#251D14;font-weight:600">
              <span class="lang-es">{place.hours.es}</span><span class="lang-en" hidden>{place.hours.en}</span>
            </div>
          </div>
          <div style="margin-bottom:22px">
            <div style="font-size:12px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#8A7D69;margin-bottom:6px">
              <span class="lang-es">Costos</span><span class="lang-en" hidden>Costs</span>
            </div>
            <div style="font-size:15px;color:#251D14;font-weight:600">
              <span class="lang-es">{place.cost.es}</span><span class="lang-en" hidden>{place.cost.en}</span>
            </div>
          </div>
          <a href="/contacto" style="display:block;text-align:center;background:#B95C36;color:#F7F1E6;font-weight:700;padding:14px;border-radius:12px;text-decoration:none">
            <span class="lang-es">Solicitar información</span><span class="lang-en" hidden>Request information</span>
          </a>
        </div>

        <div style="position:relative;aspect-ratio:1.3;border-radius:18px;overflow:hidden;border:1px solid rgba(37,29,20,.1)">
          <iframe
            title="Mapa"
            src="https://www.openstreetmap.org/export/embed.html?bbox=-82.47%2C8.74%2C-82.40%2C8.81&layer=mapnik&marker=8.7798%2C-82.4419"
            style="position:absolute;inset:0;width:100%;height:100%;border:0;filter:saturate(.85)"
            loading="lazy"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

</Layout>
