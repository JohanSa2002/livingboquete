---
import Layout from '../layouts/Layout.astro';
import GalleryMasonry from '../components/GalleryMasonry';
import { GALLERY, GALLERY_CATS } from '../data/data';
---

<Layout activeKey="gallery" title="Galería · Boquete" titleEn="Gallery · Boquete">

  <section class="pad-sec" style="max-width:1240px;margin:0 auto;padding:70px 26px 0">
    <div style="font-size:13px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:#B95C36;margin-bottom:14px">
      <span class="lang-es">Galería</span><span class="lang-en" hidden>Gallery</span>
    </div>
    <h1 style="font-family:'Bricolage Grotesque';font-weight:800;font-size:clamp(40px,6vw,72px);line-height:.98;letter-spacing:-.025em;margin:0 0 14px;color:#251D14">
      <span class="lang-es">Boquete en imágenes</span>
      <span class="lang-en" hidden>Boquete in pictures</span>
    </h1>
    <p style="font-size:18px;color:#5A4F42;max-width:560px;margin:0 0 30px">
      <span class="lang-es">Explora por categoría y abre cada foto a pantalla completa.</span>
      <span class="lang-en" hidden>Browse by category and open each photo full screen.</span>
    </p>
  </section>

  <section class="pad-sec" style="max-width:1240px;margin:0 auto;padding:0 26px 96px">
    <GalleryMasonry
      client:load
      items={GALLERY}
      categories={GALLERY_CATS}
    />
  </section>

</Layout>
