---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { isAuthenticated } from '../../lib/auth';
import { getDb, initDb } from '../../lib/db';

if (!isAuthenticated(Astro.cookies)) return Astro.redirect('/admin/login');

const { section } = Astro.params;
const config: Record<string, { table: string; title: string; key: string; nameField: string }> = {
  places:  { table: 'places',  title: 'Lugares',    key: 'places',  nameField: 'name' },
  events:  { table: 'events',  title: 'Eventos',    key: 'events',  nameField: 'name' },
  posts:   { table: 'posts',   title: 'Blog',       key: 'posts',   nameField: 'title' },
  rentals: { table: 'rentals', title: 'Alquileres', key: 'rentals', nameField: 'name' },
  gallery: { table: 'gallery', title: 'Galería',    key: 'gallery', nameField: 'label' },
};

const cfg = config[section!];
if (!cfg) return Astro.redirect('/admin');

initDb();
const db = getDb();
const rows = db.prepare(`SELECT * FROM ${cfg.table} ORDER BY created_at DESC`).all() as any[];
const items = rows.map(r => ({ ...JSON.parse(r.data), _created: r.created_at }));

const helpTexts: Record<string, { title: string; lines: string[] }> = {
  places: {
    title: 'Gestión de Lugares / Atractivos',
    lines: [
      'Estos lugares aparecen en la sección <strong>"Principales atractivos"</strong> de la página de inicio.',
      '<strong>ID</strong> — Identificador único tipo slug (ej: <code>volcan-baru</code>). No usar espacios ni caracteres especiales.',
      '<strong>Nombre y Categoría</strong> — Deben completarse en ambos idiomas (Español e Inglés).',
      '<strong>Descripción corta</strong> — Aparece en la tarjeta de la home. Máximo 2 líneas.',
      '<strong>Descripción larga</strong> — Se muestra al ver el detalle del lugar.',
      '<strong>Tips</strong> — Escribe un consejo por línea. Se muestran como lista con viñetas.',
      '<strong>URL de imagen</strong> — Usa una URL completa (ej: <code>https://ejemplo.com/foto.jpg</code>). Tamaño recomendado: 800×600px.',
    ],
  },
  events: {
    title: 'Gestión de Eventos',
    lines: [
      'Los eventos aparecen en la sección <strong>"Próximos eventos"</strong> de la página de inicio.',
      '<strong>Día</strong> — Solo el número del día (ej: <code>10</code>).',
      '<strong>Mes abreviado</strong> — En español y en inglés (ej: ES: <code>ENE</code>, EN: <code>JAN</code>).',
      '<strong>Rango de fechas</strong> — Formato completo (ej: ES: <code>10 – 21 Enero 2027</code>, EN: <code>Jan 10 – 21, 2027</code>).',
      '<strong>Horario</strong> — Rango de horas (ej: <code>9:00 – 22:00</code>).',
      '<strong>Lugar</strong> — Nombre del sitio donde se realiza, en ambos idiomas.',
    ],
  },
  posts: {
    title: 'Gestión del Blog',
    lines: [
      'Los artículos del blog aparecen en <strong>/blog</strong> y se muestran como preview en la página de inicio.',
      '<strong>Autor</strong> — Nombre completo del autor (ej: <code>Marta Quirós</code>).',
      '<strong>Fecha</strong> — En ambos formatos (ES: <code>12 Jun 2026</code>, EN: <code>Jun 12, 2026</code>).',
      '<strong>Extracto</strong> — Resumen corto que aparece en la tarjeta del blog. 1-2 oraciones.',
      '<strong>Cuerpo</strong> — Escribe un párrafo por línea. Cada línea será un párrafo separado en el artículo.',
      '<strong>Imagen</strong> — Foto principal del artículo. Tamaño recomendado: 800×500px.',
    ],
  },
  rentals: {
    title: 'Gestión de Alquileres',
    lines: [
      'Las propiedades aparecen en <strong>/alquiler</strong> y cada una tiene su página de detalle con mapa.',
      '<strong>Tipo</strong> — Selecciona entre Casa, B&B o Apartamento.',
      '<strong>Precio</strong> — Precio por noche en dólares, solo el número (ej: <code>120</code>).',
      '<strong>Rating</strong> — Calificación de 1.0 a 5.0 (ej: <code>4.9</code>).',
      '<strong>Amenidades</strong> — Lista separada por comas. Valores válidos: <code>wifi</code>, <code>kitchen</code>, <code>view</code>, <code>parking</code>, <code>pool</code>, <code>fireplace</code>, <code>breakfast</code>, <code>pets</code>.',
      '<strong>Latitud / Longitud</strong> — Coordenadas para el mapa. Boquete está aprox. en <code>8.78</code>, <code>-82.43</code>. Puedes obtener coordenadas desde Google Maps (click derecho → copiar coordenadas).',
    ],
  },
  gallery: {
    title: 'Gestión de la Galería',
    lines: [
      'Las fotos aparecen en la sección de <strong>galería</strong> de la página de inicio con filtro por categoría.',
      '<strong>Etiqueta</strong> — Texto descriptivo de la foto en ambos idiomas (ej: ES: <code>Volcán Barú al amanecer</code>).',
      '<strong>Categoría</strong> — Selecciona entre Naturaleza, Café, Cultura o Aventura. Determina el filtro.',
      '<strong>Imagen</strong> — URL de la foto. Tamaño recomendado: 600×600px (cuadrada).',
    ],
  },
};

const help = helpTexts[section!];
---
<AdminLayout title={cfg.title} active={cfg.key}>
  <div class="page-header">
    <div>
      <h1 class="page-title">{cfg.title}</h1>
      <p class="page-subtitle">{items.length} elementos</p>
    </div>
    <button class="btn btn-primary" id="add-btn">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Agregar
    </button>
  </div>

  {help && (
    <div class="help-box" id="help-box">
      <svg class="help-box-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
      <div class="help-box-content">
        <div class="help-box-title">{help.title}</div>
        <div class="help-box-text" id="help-details">
          <ul>
            {help.lines.map(line => <li set:html={line} />)}
          </ul>
        </div>
        <button class="help-toggle" id="help-toggle">Ocultar instrucciones</button>
      </div>
    </div>
  )}

  <div class="card">
    {items.length === 0 ? (
      <div class="empty"><p>No hay elementos</p></div>
    ) : (
      <div style="overflow-x:auto">
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Nombre (ES)</th>
              <th>Nombre (EN)</th>
              {section === 'posts' && <th>Autor</th>}
              {section === 'rentals' && <th>Precio</th>}
              <th>Imagen</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {items.map(item => {
              const nameObj = item[cfg.nameField];
              return (
                <tr>
                  <td style="font-size:12px;color:#8c8c87">{item.id}</td>
                  <td style="font-weight:600;color:#1a1918">{typeof nameObj === 'object' ? nameObj.es : nameObj}</td>
                  <td>{typeof nameObj === 'object' ? nameObj.en : '--'}</td>
                  {section === 'posts' && <td>{item.author}</td>}
                  {section === 'rentals' && <td style="font-weight:600">${item.price}/noche</td>}
                  <td>
                    {item.img && <img src={item.img} alt="" style="width:56px;height:38px;object-fit:cover;border-radius:8px;border:1px solid #ebebea" />}
                  </td>
                  <td style="white-space:nowrap">
                    <div style="display:flex;gap:6px;justify-content:flex-end">
                      <button class="btn btn-edit btn-sm edit-btn" data-id={item.id} data-json={JSON.stringify(item)}>Editar</button>
                      <button class="btn btn-danger btn-sm delete-btn" data-id={item.id}>Eliminar</button>
                    </div>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    )}
  </div>

  <!-- Modal -->
  <div id="modal" class="modal-overlay">
    <div class="modal-container">
      <div class="modal-header">
        <h2 id="modal-title">Editar</h2>
        <button class="modal-close" id="modal-close-x" aria-label="Cerrar">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
      <div class="modal-body" id="modal-body"></div>
      <div class="modal-footer">
        <button class="btn btn-secondary" id="modal-cancel">Cancelar</button>
        <button class="btn btn-primary" id="modal-save">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          Guardar
        </button>
      </div>
    </div>
  </div>

  <style is:global>
    .modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.4); backdrop-filter:blur(4px); z-index:100; align-items:center; justify-content:center; padding:20px; }
    .modal-container { background:#fff; border-radius:18px; width:100%; max-width:720px; max-height:88vh; display:flex; flex-direction:column; box-shadow:0 24px 68px rgba(0,0,0,.15); animation:modal-in .2s ease; }
    @keyframes modal-in { from { opacity:0; transform:scale(.97) translateY(8px); } to { opacity:1; transform:scale(1) translateY(0); } }
    .modal-header { padding:22px 26px 16px; display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid #f3f3f2; }
    .modal-header h2 { font-size:17px; font-weight:700; color:#1a1918; }
    .modal-close { width:32px; height:32px; display:flex; align-items:center; justify-content:center; border:none; background:transparent; color:#8c8c87; cursor:pointer; border-radius:8px; }
    .modal-close:hover { background:#f5f5f4; color:#3d3d39; }
    .modal-body { padding:24px 26px; flex:1; overflow-y:auto; display:flex; flex-direction:column; gap:20px; }
    .modal-footer { padding:16px 26px 22px; display:flex; gap:10px; justify-content:flex-end; border-top:1px solid #f3f3f2; }

    .f-group { display:flex; flex-direction:column; gap:6px; }
    .f-label { font-size:12px; font-weight:600; color:#6e6e69; text-transform:uppercase; letter-spacing:.05em; }
    .f-row { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
    .f-input, .f-textarea, .f-select {
      width:100%; padding:10px 14px; border:1px solid #dddcdb; border-radius:10px;
      font-size:14px; font-family:inherit; color:#1a1918; background:#fafaf9; outline:none; transition:all .15s;
    }
    .f-input:focus, .f-textarea:focus, .f-select:focus { border-color:#C8964A; background:#fff; box-shadow:0 0 0 3px rgba(200,150,74,.1); }
    .f-textarea { min-height:80px; resize:vertical; line-height:1.5; }
    .f-select { cursor:pointer; }
    .f-hint { font-size:11px; color:#a8a8a3; margin-top:2px; }
    .f-section { font-size:13px; font-weight:700; color:#1a1918; padding-top:8px; border-top:1px solid #f3f3f2; margin-top:4px; }
    .f-bi-label { font-size:11px; font-weight:600; color:#a8a8a3; margin-bottom:4px; }
  </style>
</AdminLayout>

<script define:vars={{ section }}>
  const table = section;
  const modal = document.getElementById('modal');
  const modalBody = document.getElementById('modal-body');
  const modalTitle = document.getElementById('modal-title');

  const SCHEMAS = {
    places: [
      { key: 'id', label: 'ID (slug)', type: 'text', hint: 'Ej: volcan-baru' },
      { key: 'name', label: 'Nombre', type: 'bilingual' },
      { key: 'cat', label: 'Categoría', type: 'bilingual', hint: 'Ej: Senderismo / Hiking' },
      { key: 'short', label: 'Descripción corta', type: 'bilingual-area' },
      { key: 'long', label: 'Descripción larga', type: 'bilingual-area' },
      { key: 'hours', label: 'Horario', type: 'bilingual' },
      { key: 'cost', label: 'Costo', type: 'bilingual' },
      { key: 'tips', label: 'Tips (uno por línea)', type: 'bilingual-list' },
      { key: 'img', label: 'URL de imagen', type: 'text' },
    ],
    events: [
      { key: 'id', label: 'ID (slug)', type: 'text' },
      { key: 'name', label: 'Nombre', type: 'bilingual' },
      { key: 'd', label: 'Día (número)', type: 'text', hint: 'Ej: 10' },
      { key: 'm', label: 'Mes abreviado', type: 'bilingual', hint: 'Ej: ENE / JAN' },
      { key: 'range', label: 'Rango de fechas', type: 'bilingual' },
      { key: 'cat', label: 'Categoría', type: 'bilingual' },
      { key: 'time', label: 'Horario', type: 'bilingual' },
      { key: 'place', label: 'Lugar', type: 'bilingual' },
      { key: 'desc', label: 'Descripción', type: 'bilingual-area' },
      { key: 'img', label: 'URL de imagen', type: 'text' },
    ],
    posts: [
      { key: 'id', label: 'ID (slug)', type: 'text' },
      { key: 'title', label: 'Título', type: 'bilingual' },
      { key: 'author', label: 'Autor', type: 'text' },
      { key: 'date', label: 'Fecha', type: 'bilingual', hint: 'Ej: 12 Jun 2026 / Jun 12, 2026' },
      { key: 'cat', label: 'Categoría', type: 'bilingual' },
      { key: 'excerpt', label: 'Extracto', type: 'bilingual-area' },
      { key: 'body', label: 'Cuerpo (un párrafo por línea)', type: 'bilingual-list' },
      { key: 'img', label: 'URL de imagen', type: 'text' },
    ],
    rentals: [
      { key: 'id', label: 'ID (slug)', type: 'text' },
      { key: 'name', label: 'Nombre', type: 'bilingual' },
      { key: 'type', label: 'Tipo', type: 'select', options: [['casa','Casa'],['bnb','B&B'],['apto','Apartamento']] },
      { key: 'price', label: 'Precio por noche ($)', type: 'number' },
      { key: 'guests', label: 'Huéspedes', type: 'number' },
      { key: 'beds', label: 'Camas', type: 'number' },
      { key: 'baths', label: 'Baños', type: 'number' },
      { key: 'rating', label: 'Rating', type: 'number' },
      { key: 'reviews', label: 'Num. reseñas', type: 'number' },
      { key: 'loc', label: 'Ubicación', type: 'bilingual' },
      { key: 'short', label: 'Descripción corta', type: 'bilingual-area' },
      { key: 'desc', label: 'Descripción larga', type: 'bilingual-area' },
      { key: 'amen', label: 'Amenidades (separadas por coma)', type: 'text', hint: 'wifi, kitchen, view, parking, pool, fireplace, breakfast, pets' },
      { key: 'lat', label: 'Latitud', type: 'number' },
      { key: 'lng', label: 'Longitud', type: 'number' },
      { key: 'img', label: 'URL de imagen', type: 'text' },
    ],
    gallery: [
      { key: 'id', label: 'ID (slug)', type: 'text' },
      { key: 'label', label: 'Etiqueta', type: 'bilingual' },
      { key: 'cat', label: 'Categoría', type: 'select', options: [['naturaleza','Naturaleza'],['cafe','Café'],['cultura','Cultura'],['aventura','Aventura']] },
      { key: 'img', label: 'URL de imagen', type: 'text' },
    ],
  };

  const schema = SCHEMAS[table] || [];

  function buildForm(data) {
    let html = '';
    for (const field of schema) {
      const val = data[field.key];
      const placeholders = {
        id: 'ej: mi-nuevo-lugar',
        img: 'https://ejemplo.com/imagen.jpg',
        author: 'Nombre del autor',
        d: 'ej: 10',
        price: 'ej: 120',
        guests: 'ej: 6',
        beds: 'ej: 3',
        baths: 'ej: 2',
        rating: 'ej: 4.9',
        reviews: 'ej: 128',
        amen: 'wifi, kitchen, view, parking',
        lat: 'ej: 8.7835',
        lng: 'ej: -82.4389',
      };
      const ph = placeholders[field.key] || '';

      if (field.type === 'text') {
        html += `<div class="f-group">
          <label class="f-label">${field.label}</label>
          <input class="f-input" data-key="${field.key}" value="${esc(typeof val === 'string' ? val : (Array.isArray(val) ? val.join(', ') : ''))}" placeholder="${ph}" />
          ${field.hint ? `<span class="f-hint">${field.hint}</span>` : ''}
        </div>`;
      } else if (field.type === 'number') {
        html += `<div class="f-group">
          <label class="f-label">${field.label}</label>
          <input class="f-input" type="number" step="any" data-key="${field.key}" value="${val ?? ''}" placeholder="${ph}" />
        </div>`;
      } else if (field.type === 'select') {
        const opts = field.options.map(([v, l]) => `<option value="${v}" ${val === v ? 'selected' : ''}>${l}</option>`).join('');
        html += `<div class="f-group">
          <label class="f-label">${field.label}</label>
          <select class="f-select" data-key="${field.key}">${opts}</select>
        </div>`;
      } else if (field.type === 'bilingual') {
        const esVal = val?.es ?? '';
        const enVal = val?.en ?? '';
        html += `<div class="f-group">
          <label class="f-label">${field.label}</label>
          <div class="f-row">
            <div><div class="f-bi-label">Español</div><input class="f-input" data-key="${field.key}" data-lang="es" value="${esc(esVal)}" /></div>
            <div><div class="f-bi-label">English</div><input class="f-input" data-key="${field.key}" data-lang="en" value="${esc(enVal)}" /></div>
          </div>
          ${field.hint ? `<span class="f-hint">${field.hint}</span>` : ''}
        </div>`;
      } else if (field.type === 'bilingual-area') {
        const esVal = val?.es ?? '';
        const enVal = val?.en ?? '';
        html += `<div class="f-group">
          <label class="f-label">${field.label}</label>
          <div class="f-row">
            <div><div class="f-bi-label">Español</div><textarea class="f-textarea" data-key="${field.key}" data-lang="es">${esc(esVal)}</textarea></div>
            <div><div class="f-bi-label">English</div><textarea class="f-textarea" data-key="${field.key}" data-lang="en">${esc(enVal)}</textarea></div>
          </div>
        </div>`;
      } else if (field.type === 'bilingual-list') {
        const esVal = Array.isArray(val?.es) ? val.es.join('\n') : '';
        const enVal = Array.isArray(val?.en) ? val.en.join('\n') : '';
        html += `<div class="f-group">
          <label class="f-label">${field.label}</label>
          <div class="f-row">
            <div><div class="f-bi-label">Español</div><textarea class="f-textarea" data-key="${field.key}" data-lang="es" data-list="true">${esc(esVal)}</textarea></div>
            <div><div class="f-bi-label">English</div><textarea class="f-textarea" data-key="${field.key}" data-lang="en" data-list="true">${esc(enVal)}</textarea></div>
          </div>
          ${field.hint ? `<span class="f-hint">${field.hint}</span>` : ''}
        </div>`;
      }
    }
    return html;
  }

  function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  function collectForm() {
    const data = {};
    modalBody.querySelectorAll('[data-key]').forEach(el => {
      const key = el.dataset.key;
      const lang = el.dataset.lang;
      const isList = el.dataset.list === 'true';
      let val = el.value;

      if (lang) {
        if (!data[key]) data[key] = {};
        data[key][lang] = isList ? val.split('\n').filter(l => l.trim()) : val;
      } else if (el.type === 'number') {
        data[key] = val ? Number(val) : 0;
      } else if (key === 'amen') {
        data[key] = val.split(',').map(s => s.trim()).filter(Boolean);
      } else {
        data[key] = val;
      }
    });
    return data;
  }

  function showModal(title, data) {
    modalTitle.textContent = title;
    modalBody.innerHTML = buildForm(data);
    modal.style.display = 'flex';
  }
  function hideModal() { modal.style.display = 'none'; }

  document.getElementById('modal-cancel').addEventListener('click', hideModal);
  document.getElementById('modal-close-x').addEventListener('click', hideModal);
  modal.addEventListener('click', (e) => { if (e.target === modal) hideModal(); });

  document.getElementById('add-btn').addEventListener('click', () => {
    showModal('Agregar nuevo', {});
  });

  document.querySelectorAll('.edit-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = JSON.parse(btn.dataset.json);
      delete item._created;
      delete item._updated;
      showModal('Editar: ' + item.id, item);
    });
  });

  document.getElementById('modal-save').addEventListener('click', async () => {
    const data = collectForm();
    if (!data.id) { alert('El campo ID es obligatorio'); return; }
    const res = await fetch(`/api/content/${table}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    });
    if (res.ok) { window.location.reload(); }
    else { alert('Error al guardar'); }
  });

  document.querySelectorAll('.delete-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!confirm('¿Eliminar este elemento?')) return;
      await fetch(`/api/content/${table}`, {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: btn.dataset.id }),
      });
      btn.closest('tr')?.remove();
    });
  });

  // Help toggle
  const helpToggle = document.getElementById('help-toggle');
  const helpDetails = document.getElementById('help-details');
  if (helpToggle && helpDetails) {
    const stored = localStorage.getItem('admin-help-hidden');
    if (stored === 'true') {
      helpDetails.style.display = 'none';
      helpToggle.textContent = 'Mostrar instrucciones';
    }
    helpToggle.addEventListener('click', () => {
      const isHidden = helpDetails.style.display === 'none';
      helpDetails.style.display = isHidden ? '' : 'none';
      helpToggle.textContent = isHidden ? 'Ocultar instrucciones' : 'Mostrar instrucciones';
      localStorage.setItem('admin-help-hidden', String(!isHidden));
    });
  }
</script>
