---
import Layout from '../layouts/Layout.astro';
import { EVENTS } from '../data/data';
---

<Layout activeKey="events" title="Eventos · Boquete" titleEn="Events · Boquete">

  <section class="pad-sec" style="max-width:1100px;margin:0 auto;padding:70px 26px 0">
    <div style="font-size:13px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:#B95C36;margin-bottom:14px">
      <span class="lang-es">Agenda</span><span class="lang-en" hidden>Agenda</span>
    </div>
    <h1 style="font-family:'Bricolage Grotesque';font-weight:800;font-size:clamp(40px,6vw,72px);line-height:.98;letter-spacing:-.025em;margin:0 0 14px;color:#251D14">
      <span class="lang-es">Eventos y festivales</span>
      <span class="lang-en" hidden>Events &amp; festivals</span>
    </h1>
    <p style="font-size:18px;color:#5A4F42;max-width:540px;margin:0 0 46px">
      <span class="lang-es">Lo mejor del calendario boqueteño para planear tu visita.</span>
      <span class="lang-en" hidden>The best of the Boquete calendar to plan your visit.</span>
    </p>
  </section>

  <section class="pad-sec" style="max-width:1100px;margin:0 auto;padding:0 26px 96px;display:flex;flex-direction:column;gap:22px">
    {EVENTS.map(e => (
      <div class="ev-row rv" style="display:flex;gap:0;background:#fff;border:1px solid rgba(37,29,20,.09);border-radius:20px;overflow:hidden;box-shadow:0 1px 2px rgba(37,29,20,.04)">
        <div style="position:relative;width:300px;flex:none;min-height:220px">
          <img src={e.img} alt={e.name.es} style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover" loading="lazy" />
          <div style="position:absolute;top:14px;left:14px;background:#F7F1E6;border-radius:13px;text-align:center;padding:9px 14px;line-height:1">
            <div style="font-family:'Bricolage Grotesque';font-weight:800;font-size:26px;color:#B95C36">{e.d}</div>
            <div style="font-size:11px;font-weight:700;letter-spacing:.1em;color:#5A4F42;margin-top:2px">
              <span class="lang-es">{e.m.es}</span><span class="lang-en" hidden>{e.m.en}</span>
            </div>
          </div>
        </div>
        <div style="padding:26px 28px;display:flex;flex-direction:column;justify-content:center;flex:1">
          <span style="font-size:12.5px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:#C8964A;margin-bottom:8px">
            <span class="lang-es">{e.cat.es} · {e.range.es}</span>
            <span class="lang-en" hidden>{e.cat.en} · {e.range.en}</span>
          </span>
          <h3 style="font-family:'Bricolage Grotesque';font-weight:700;font-size:25px;margin:0 0 10px;color:#251D14;letter-spacing:-.01em">
            <span class="lang-es">{e.name.es}</span><span class="lang-en" hidden>{e.name.en}</span>
          </h3>
          <p style="font-size:15px;line-height:1.6;color:#5A4F42;margin:0 0 16px;max-width:560px">
            <span class="lang-es">{e.desc.es}</span><span class="lang-en" hidden>{e.desc.en}</span>
          </p>
          <div style="display:flex;gap:22px;flex-wrap:wrap;align-items:center">
            <span style="font-size:14px;color:#3D3328">
              <b style="color:#8A7D69;font-weight:700"><span class="lang-es">Hora</span><span class="lang-en" hidden>Time</span>:</b>&nbsp;
              <span class="lang-es">{e.time.es}</span><span class="lang-en" hidden>{e.time.en}</span>
            </span>
            <span style="font-size:14px;color:#3D3328">
              <b style="color:#8A7D69;font-weight:700"><span class="lang-es">Lugar</span><span class="lang-en" hidden>Where</span>:</b>&nbsp;
              <span class="lang-es">{e.place.es}</span><span class="lang-en" hidden>{e.place.en}</span>
            </span>
            <a href="/contacto" style="cursor:pointer;margin-left:auto;color:#B95C36;font-weight:700;font-size:14px;text-decoration:none;white-space:nowrap">
              <span class="lang-es">Más información</span><span class="lang-en" hidden>More info</span> →
            </a>
          </div>
        </div>
      </div>
    ))}
  </section>

</Layout>
